        "html": "<h2>Nouvelle demande nécessitant une intervention humaine</h2><p><strong>Raison d'escalade :</strong> {{ $node[\"AI Agent\"].json.raison }}</p><p><strong>Résumé prospect :</strong></p><pre>{{ $node[\"AI Agent\"].json.resume }}</pre><p>Merci de recontacter le prospect sous 24h.</p>"
      },
      "type": "n8n-nodes-base.resend",
      "typeVersion": 1,
      "position": [1250, 700],
      "id": "node-email-commercial",
      "name": "Notifier Commercial",
      "credentials": {
        "resendApi": {
          "id": "REMPLACER_PAR_CREDENTIAL_ID",
          "name": "Resend API"
        }
      }
    },
    {
      "parameters": {
        "respondWith": "json",
        "responseBody": "={{ JSON.stringify({ success: true, message: \"Votre demande nécessite une étude personnalisée. Un conseiller NeoTravel vous recontacte sous 24h.\", statut: \"cas_complexe\" }) }}",
        "options": {
          "responseCode": 200
        }
      },
      "type": "n8n-nodes-base.respondToWebhook",
