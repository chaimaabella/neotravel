      "typeVersion": 1.1,
      "position": [2250, 0],
      "id": "node-respond-succes",
      "name": "Respond Succès"
    },
    {
      "parameters": {
        "jsCode": "const urgence = $node[\"AI Agent\"].json.donnees.urgence;\nconst delaiJours = (urgence === \"DD_PRIORITAIRE\" || urgence === \"DD_URGENT\") ? 2 : 3;\nconst dateRelance = new Date(Date.now() + delaiJours * 86400000).toISOString().split('T')[0];\nreturn { delai_jours: delaiJours, date_relance: dateRelance, email: $node[\"AI Agent\"].json.donnees.email, nom_societe: $node[\"AI Agent\"].json.donnees.nom_societe, prix_ttc: $node[\"Calculer Devis\"].json.prix_ttc };"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [2250, 200],
      "id": "node-calcul-relance",
      "name": "Calcul Délai Relance"
    },
    {
      "parameters": {
        "amount": "={{ $json.delai_jours }}",
        "unit": "days"
      },
      "type": "n8n-nodes-base.wait",
      "typeVersion": 1.1,
      "position": [2500, 200],
      "id": "node-wait-relance",
      "name": "Attente Relance"
    },
    {
      "parameters": {
        "fromEmail": "relance@neotravel.fr",
        "toEmail": "={{ $json.email }}",
        "subject": "Relance — Votre devis NeoTravel est en attente",
        "html": "<h2>Bonjour,</h2><p>Nous vous avons envoyé un devis de <strong>{{ $json.prix_ttc }} € TTC</strong> pour votre société <strong>{{ $json.nom_societe }}</strong>.</p><p>Avez-vous des questions ? Nous restons à votre disposition pour finaliser votre réservation.</p><p>Cordialement,<br/><strong>L'équipe NeoTravel</strong></p>"
      },
      "type": "n8n-nodes-base.resend",
      "typeVersion": 1,
      "position": [2750, 200],
      "id": "node-email-relance",
      "name": "Envoyer Relance Email",
      "credentials": {
        "resendApi": {
          "id": "REMPLACER_PAR_CREDENTIAL_ID",
          "name": "Resend API"
        }
      }
    },

    {
      "parameters": {
        "respondWith": "json",
        "responseBody": "={{ JSON.stringify({ success: false, message: $json.message, champs_manquants: $json.champs_manquants }) }}",
        "options": {
          "responseCode": 422
        }
      },
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1.1,
      "position": [1000, 500],
      "id": "node-respond-incomplet",
      "name": "Respond Incomplet"
    },

    {
      "parameters": {
