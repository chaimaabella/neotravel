            "index": 0
          }
        ],
        [
          {
            "node": "Respond Incomplet",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Calculer Devis": {
      "main": [
        [
          {
            "node": "Airtable CRM",
